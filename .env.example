SKIP_PREFLIGHT_CHECK=true
GENERATE_SOURCEMAP=false

# ── Firebase (Araksha project) ─────────────────────────────────────────────
# Create a new Firebase project at https://console.firebase.google.com
# Project settings → General → Your apps → Web app → SDK setup and configuration
REACT_APP_FIREBASE_API_KEY=REPLACE_WITH_ARAKSHA_FIREBASE_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_ARAKSHA_PROJECT.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=REPLACE_WITH_ARAKSHA_PROJECT_ID
REACT_APP_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_ARAKSHA_PROJECT.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
REACT_APP_FIREBASE_APP_ID=REPLACE_WITH_APP_ID

# ── EmailJS ────────────────────────────────────────────────────────────────
# Get from emailjs.com → Email Services (Service ID) + Email Templates (Template ID) + Account → API Keys (Public Key)
REACT_APP_EMAILJS_SERVICE_ID=REPLACE_WITH_EMAILJS_SERVICE_ID
REACT_APP_EMAILJS_TEMPLATE_ID=REPLACE_WITH_EMAILJS_TEMPLATE_ID
REACT_APP_EMAILJS_PUBLIC_KEY=REPLACE_WITH_EMAILJS_PUBLIC_KEY
REACT_APP_EMAILJS_CUSTOMER_TEMPLATE_ID=REPLACE_WITH_EMAILJS_CUSTOMER_TEMPLATE_ID
